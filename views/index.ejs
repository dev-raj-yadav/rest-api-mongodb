<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Whatsapp</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    
   <form method="GET" action="/chats/new">
      <button>New Chat</button>
   </form>
<h3>All Chats!</h3>
<% for(let chat of chats){ %>
<div class="chat">

   <p>From : <%= chat.from %> </p>
   <div class="msg">
   <p><%= chat.msg %> </p>
   <form action="/chats/<%=chat._id%>/edit"><Button>Edit</Button></form>
   </div>
   <p>Received by <%= chat.to %> </p>
   <hr>
   <p><%= chat.created_at.toString().split(" ")[4] %> <br> </p>
      <p><%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %> <br> </p>
</div>
<br> <br>
<%} %>
  
</body>
</html>